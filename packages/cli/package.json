{
  "name": "@uni-pages-weave/cli",
  "version": "0.1.0",
  "description": "UPW command line interface.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "upw": "./bin/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src"
  },
  "dependencies": {
    "@uni-pages-weave/core": "workspace:*",
    "commander": "^12.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
