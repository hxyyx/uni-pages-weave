{
  "name": "@uni-pages-weave/core",
  "version": "0.1.3",
  "description": "Core upw pages.json compiler APIs.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js",
      "require": "./dist/logger.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "fs-extra": "^11.2.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.21",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
