{
  "name": "validateUpwAppConfig rejects patching upw metadata and compile-time app fields",
  "kind": "validate-upw-app-errors",
  "inputs": [
    {
      "config": {
        "$upw": {
          "homePath": "pages/index/index",
          "patches": [
            {
              "when": ["h5"],
              "patch": {
                "$upw": {}
              }
            }
          ]
        }
      },
      "errorPattern": "\\$upw is upw metadata and cannot be conditionally patched"
    },
    {
      "config": {
        "$upw": {
          "homePath": "pages/index/index",
          "patches": [
            {
              "when": ["h5"],
              "patch": {
                "subPackages": []
              }
            }
          ]
        }
      },
      "errorPattern": "subPackages is an upw compile-time structure field and cannot be conditionally patched"
    },
    {
      "config": {
        "$upw": {
          "homePath": "pages/index/index",
          "patches": [
            {
              "when": ["h5"],
              "patch": {
                "subpackages": []
              }
            }
          ]
        }
      },
      "errorPattern": "subpackages is a uni-app compatibility alias of subPackages and cannot be conditionally patched"
    },
    {
      "config": {
        "$upw": {
          "homePath": "pages/index/index",
          "patches": [
            {
              "when": ["h5"],
              "patch": {
                "pages": []
              }
            }
          ]
        }
      },
      "errorPattern": "pages is generated from page-level upw files and cannot be conditionally patched"
    }
  ]
}
