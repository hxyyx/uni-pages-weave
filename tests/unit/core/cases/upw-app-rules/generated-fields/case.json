{
  "name": "validateUpwAppConfig rejects generated and UPW-managed app fields",
  "kind": "validate-upw-app-errors",
  "inputs": [
    {
      "config": {
        "pages": [],
        "$upw": {
          "homePath": "pages/index/index"
        }
      },
      "errorPattern": "pages is generated from page-level UPW files"
    },
    {
      "config": {
        "subPackages": [
          {
            "name": "account",
            "root": "pages/account",
            "pages": []
          }
        ],
        "$upw": {
          "homePath": "pages/index/index"
        }
      },
      "errorPattern": "subPackages\\[0\\]\\.pages is generated from page-level UPW files"
    }
  ]
}
