{
  "name": "pagePathToWorkspaceFile maps page paths into upw workspace files",
  "kind": "page-path-to-workspace-file",
  "input": {
    "root": ["tmp", "upw"],
    "pages": [
      {
        "path": "pages/index/index",
        "expected": ["tmp", "upw", "pages", "index", "index.upw.json"]
      },
      {
        "path": "platforms/mp-weixin/pages/index/index",
        "expected": ["tmp", "upw", "platforms", "mp-weixin", "pages", "index", "index.upw.json"]
      }
    ]
  }
}
