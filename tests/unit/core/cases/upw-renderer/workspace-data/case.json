{
  "name": "renderUpwToUniPagesJson renders workspace data with subPackages",
  "kind": "render-upw-to-uni",
  "input": {
    "render": {
      "type": "workspace",
      "data": {
        "app": {
          "globalStyle": {
            "navigationBarTitleText": "Demo"
          },
          "subPackages": [
            {
              "name": "account",
              "root": "pages/account"
            }
          ],
          "$upw": {
            "homePath": "pages/index/index"
          }
        },
        "pages": [
          {
            "path": "pages/index/index",
            "style": {
              "navigationBarTitleText": "Home"
            }
          },
          {
            "$upw": {
              "subPackageName": "account"
            },
            "path": "pages/account/profile/profile",
            "style": {
              "navigationBarTitleText": "Profile"
            }
          }
        ]
      }
    }
  },
  "expected": {
    "contains": [
      "\"pages\"",
      "\"subPackages\"",
      "\"root\": \"pages/account\"",
      "\"path\": \"profile/profile\""
    ],
    "notContains": ["\"subpackages\"", "\"$upw\""]
  }
}
