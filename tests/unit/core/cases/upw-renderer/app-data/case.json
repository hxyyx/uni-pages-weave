{
  "name": "renderUpwToUniPagesJson renders app data as uni-app pages.json fields",
  "kind": "render-upw-to-uni",
  "input": {
    "render": {
      "type": "app",
      "data": {
        "globalStyle": {
          "navigationBarTitleText": "Demo"
        },
        "$upw": {
          "homePath": "pages/index/index",
          "patches": [
            {
              "when": ["h5"],
              "patch": {
                "globalStyle": {
                  "navigationBarTitleText": "H5"
                }
              }
            }
          ]
        }
      }
    }
  },
  "expected": {
    "contains": [
      "\"globalStyle\"",
      "// #ifdef H5",
      "\"navigationBarTitleText\": \"H5\""
    ],
    "notContains": ["\"homePath\"", "\"$upw\""]
  }
}
